# =============================================================================
# .env.example  ->  copy to .env and fill in. NEVER commit the real .env.
# =============================================================================

# --- Django core ------------------------------------------------------------
# Generate once with:  python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-to-a-long-random-string

# MUST be False in production. (The old version ran DEBUG=True, which is what
# bypassed hashed static URLs and caused the stale-asset problem.)
DEBUG=False

# Comma-separated hostnames the app will serve. Replace '*' from settings.
ALLOWED_HOSTS=your.domain.com,localhost
CSRF_TRUSTED_ORIGINS=https://your.domain.com

# --- database ---------------------------------------------------------------
DB_NAME=financee
DB_USER=financee
DB_PASSWORD=change-me-strong
DB_HOST=db          # docker-compose service name; overridden in compose anyway
DB_PORT=5432

# --- gunicorn (optional overrides; sensible defaults in gunicorn.conf.py) ----
# WEB_CONCURRENCY=4
# GUNICORN_THREADS=4
# GUNICORN_TIMEOUT=60

# --- persistent DB connections (set in settings patch) ----------------------
# CONN_MAX_AGE=60
